{
  "name": "kiki",
  "version": "2.1.0",
  "description": "OpenCode agent orchestration framework with static routing, parallel execution, and structured workflow",
  "license": "MIT",
  "keywords": ["opencode", "ai", "routing", "agent", "orchestration"],
  "repository": {
    "type": "git",
    "url": "https://github.com/luxuxorg/kiki.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "files": ["dist/"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "kiki": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node dist/cli/index.js"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^18.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
